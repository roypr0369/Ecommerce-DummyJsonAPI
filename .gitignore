# ===============================
# IDE files
# ===============================
.idea/
*.iml
*.iws
*.ipr
.vscode/

# ===============================
# Build folders
# ===============================
target/          # Maven
build/           # Gradle
out/

# ===============================
# Logs
# ===============================
logs/
*.log

# ===============================
# OS files
# ===============================
.DS_Store
Thumbs.db

# ===============================
# Environment / secrets
# ===============================
.env
*.env
application-*.yml
application-*.properties

# Keep default config but ignore local overrides
!src/main/resources/application.yml
!src/main/resources/application.properties

# ===============================
# Java compiled files
# ===============================
*.class

# ===============================
# Temporary files
# ===============================
*.tmp
*.swp
*.swo

# ===============================
# Maven wrapper (keep wrapper, ignore jar if needed)
# ===============================
.mvn/wrapper/maven-wrapper.jar

# ===============================
# Gradle wrapper
# ===============================
.gradle/
gradle-app.setting
!gradlew
!gradlew.bat
!gradle/wrapper/gradle-wrapper.jar

# ===============================
# Test output
# ===============================
/test-output/
/surefire-reports/

# ===============================
# Coverage reports
# ===============================
/coverage/
/jacoco.exec

# ===============================
# Misc
# ===============================
*.pid
*.seed
*.lock